{
  "name": "mini-ticketbox",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @mini-ticketbox/web --filter @mini-ticketbox/api dev",
    "dev:web": "corepack pnpm --filter @mini-ticketbox/web dev",
